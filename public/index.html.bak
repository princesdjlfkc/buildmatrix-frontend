<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>BUILDMATRIX - Ultimate PC Builder</title>

  <link rel="stylesheet" href="style.css" />
  <link rel="manifest" href="manifest.json">
  <meta name="apple-mobile-web-app-capable" content="yes">
  <meta name="apple-mobile-web-app-status-bar-style" content="default">
  <meta name="apple-mobile-web-app-title" content="BuildMatrix">
  <meta name="theme-color" content="#000000">
  <link rel="apple-touch-icon" href="icons/icon-192.png">

  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">

  <script src="https://cdnjs.cloudflare.com/ajax/libs/html2canvas/1.4.1/html2canvas.min.js" defer></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js" defer></script>

  <script src="products-data.js"></script>
  <script src="products-ui.js"></script>
  <script src="common.js"></script>
  <script src="builder.js"></script>
  
  <style>
    /* COMPLETE DROPDOWN FIX - NO COLLISION */
    * {
      box-sizing: border-box;
    }
    
    /* Force all containers to allow overflow */
    html, body {
      overflow-x: hidden !important;
      overflow-y: auto !important;
      position: relative;
    }
    
    .builder-container,
    .builder-main,
    .builder-sidebar,
    .build-panel,
    .main-nav,
    header,
    .header-container,
    nav,
    .categories-list,
    .selected-parts {
      position: relative;
    }
    
    /* Sidebar and panel - sticky with scroll */
    .builder-sidebar {
      overflow-y: auto !important;
      overflow-x: hidden !important;
      position: sticky;
      top: 100px;
      z-index: 10;
    }
    
    .build-panel {
      overflow-y: auto !important;
      overflow-x: hidden !important;
      position: sticky;
      top: 100px;
      z-index: 10;
    }
    
    .builder-main {
      position: sticky;
      top: 100px;
      max-height: calc(100vh - 120px);
      overflow-y: auto !important;
      overflow-x: hidden !important;
      z-index: 5;
    }
    
    /* DROPDOWN STYLES - POSITIONED CORRECTLY */
    .nav-item {
      position: relative !important;
    }
    
    .nav-item .dropdown {
      position: absolute !important;
      top: calc(100% + 5px) !important;
      left: 0 !important;
      z-index: 999999 !important;
      background: #111111 !important;
      backdrop-filter: blur(20px);
      border: 1px solid #FFD700 !important;
      border-radius: 12px !important;
      min-width: 240px !important;
      opacity: 0;
      visibility: hidden;
      transition: opacity 0.25s ease, visibility 0.25s ease, transform 0.25s ease;
      pointer-events: none;
      box-shadow: 0 15px 35px rgba(0, 0, 0, 0.5), 0 0 0 1px rgba(255, 215, 0, 0.2) !important;
      margin: 0 !important;
      transform: translateY(-8px);
    }
    
    .nav-item:hover .dropdown {
      opacity: 1 !important;
      visibility: visible !important;
      pointer-events: auto !important;
      transform: translateY(0) !important;
    }
    
    /* Dropdown content */
    .dropdown-content {
      padding: 8px 0 !important;
    }
    
    .dropdown-content a {
      display: block !important;
      padding: 12px 24px !important;
      color: #cccccc !important;
      text-decoration: none !important;
      font-size: 14px !important;
      font-weight: 500 !important;
      transition: all 0.2s ease !important;
      cursor: pointer !important;
      white-space: nowrap !important;
      border-left: 3px solid transparent !important;
    }
    
    .dropdown-content a:hover {
      background: rgba(255, 215, 0, 0.15) !important;
      color: #FFD700 !important;
      border-left-color: #FFD700 !important;
      padding-left: 28px !important;
    }
    
    /* Header stays on top */
    header {
      position: sticky;
      top: 0;
      z-index: 1000;
      background: rgba(10, 10, 10, 0.98);
      backdrop-filter: blur(20px);
      border-bottom: 1px solid rgba(255, 215, 0, 0.2);
    }
    
    .main-nav {
      z-index: 1001;
      position: relative;
    }
    
    /* Fix product grid spacing */
    .products-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
      gap: 20px;
      position: relative;
    }
    
    .product-card {
      background: rgba(17, 17, 17, 0.95);
      backdrop-filter: blur(10px);
      border-radius: 16px;
      overflow: hidden;
      border: 1px solid #222;
      transition: all 0.3s ease;
      cursor: pointer;
    }
    
    .product-card:hover {
      transform: translateY(-4px);
      border-color: #FFD700;
      box-shadow: 0 10px 30px rgba(0, 0, 0, 0.3);
    }
    
    /* Ensure sidebar categories don't overlap dropdown */
    .categories-list {
      position: relative;
      z-index: 1;
    }
    
    /* Pagination Styles */
    .pagination-container {
      margin-top: 30px;
      padding: 20px;
      display: flex;
      justify-content: center;
      gap: 10px;
      flex-wrap: wrap;
    }
    
    .page-btn {
      background: rgba(255, 215, 0, 0.1);
      border: 1px solid #FFD700;
      color: #FFD700;
      padding: 8px 16px;
      border-radius: 8px;
      cursor: pointer;
      transition: all 0.3s ease;
      font-weight: 600;
    }
    
    .page-btn:hover {
      background: #FFD700;
      color: #0A0A0A;
    }
    
    .page-btn.active {
      background: #FFD700;
      color: #0A0A0A;
    }
    
    .page-numbers {
      display: flex;
      gap: 8px;
      flex-wrap: wrap;
      justify-content: center;
    }
    
    /* Responsive fix */
    @media (max-width: 1200px) {
      .nav-item .dropdown {
        left: 0 !important;
        min-width: 200px !important;
      }
    }
    
    @media (max-width: 992px) {
      .builder-sidebar,
      .build-panel {
        position: static !important;
      }
      
      .nav-item .dropdown {
        position: fixed !important;
        top: auto !important;
        left: 20px !important;
        right: 20px !important;
        width: auto !important;
        max-height: 60vh;
        overflow-y: auto;
      }
    }
    
    /* Fix for any hidden overflow */
    .video-hero,
    .guides-section,
    .newsletter-section,
    .footer {
      overflow: visible !important;
    }

    /* ══ USER MENU DROPDOWN ══════════════════════════════════ */
    .user-menu-container {
      position: relative;
      display: flex;
      align-items: center;
    }

    .user-menu-trigger {
      display: flex;
      align-items: center;
      gap: 9px;
      padding: 6px 12px 6px 6px;
      border-radius: 10px;
      border: 1px solid rgba(255,215,0,0.3);
      background: rgba(255,215,0,0.08);
      cursor: pointer;
      transition: all 0.2s;
      user-select: none;
    }

    .user-menu-trigger:hover {
      background: rgba(255,215,0,0.15);
      border-color: rgba(255,215,0,0.5);
    }

    .um-avatar {
      width: 30px;
      height: 30px;
      border-radius: 50%;
      background: linear-gradient(135deg, #FFD700, #FFA500);
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 12px;
      font-weight: 800;
      color: #000;
      overflow: hidden;
      flex-shrink: 0;
    }

    .um-avatar img { width:100%; height:100%; object-fit:cover; border-radius:50%; }

    #userNameHeader {
      font-size: 13px;
      font-weight: 600;
      color: #FFD700;
      max-width: 110px;
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: nowrap;
    }

    #umChevron {
      font-size: 10px;
      color: rgba(255,215,0,0.6);
      transition: transform 0.2s;
    }

    .user-menu-trigger.open #umChevron { transform: rotate(180deg); }

    .user-dropdown {
      display: none;
      position: absolute;
      top: calc(100% + 12px);
      right: 0;
      background: #111;
      border: 1px solid rgba(255,215,0,0.2);
      border-radius: 14px;
      min-width: 220px;
      padding: 6px 0;
      box-shadow: 0 20px 50px rgba(0,0,0,0.75), 0 0 0 1px rgba(255,215,0,0.08);
      z-index: 999999;
      animation: udIn 0.18s ease;
    }

    @keyframes udIn {
      from { opacity:0; transform:translateY(-8px) scale(0.97); }
      to   { opacity:1; transform:translateY(0) scale(1); }
    }

    .user-dropdown.show { display: block; }

    .ud-header {
      display: flex;
      align-items: center;
      gap: 12px;
      padding: 12px 16px 12px;
      border-bottom: 1px solid rgba(255,255,255,0.07);
      margin-bottom: 4px;
    }

    .ud-avatar {
      width: 40px;
      height: 40px;
      border-radius: 50%;
      background: linear-gradient(135deg, #FFD700, #FFA500);
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 15px;
      font-weight: 800;
      color: #000;
      overflow: hidden;
      flex-shrink: 0;
      border: 2px solid rgba(255,215,0,0.3);
    }

    .ud-avatar img { width:100%; height:100%; object-fit:cover; border-radius:50%; }

    .ud-info { overflow: hidden; }

    .ud-info strong {
      display: block;
      font-size: 13px;
      font-weight: 700;
      color: #f0f0f0;
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: nowrap;
    }

    .ud-info span {
      font-size: 11px;
      color: #555;
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: nowrap;
      display: block;
    }

    .user-dropdown a {
      display: flex;
      align-items: center;
      gap: 10px;
      padding: 10px 16px;
      font-size: 13px;
      font-weight: 500;
      color: #aaa;
      text-decoration: none;
      transition: all 0.15s;
    }

    .user-dropdown a:hover {
      background: rgba(255,255,255,0.05);
      color: #f0f0f0;
    }

    .user-dropdown a i {
      width: 16px;
      text-align: center;
      font-size: 13px;
      color: #555;
    }

    .user-dropdown a:hover i { color: #FFD700; }

    .user-dropdown a#adminMenuBtn { color: #FFD700; }
    .user-dropdown a#adminMenuBtn i { color: #FFD700; }

    .user-dropdown hr {
      border: none;
      border-top: 1px solid rgba(255,255,255,0.07);
      margin: 4px 0;
    }

    .user-dropdown .ud-signout { color: #ef4444 !important; }
    .user-dropdown .ud-signout i { color: #ef4444 !important; }
    .user-dropdown .ud-signout:hover { background: rgba(239,68,68,0.08) !important; }
    .forgot-link { color: #FFD700 !important; font-size: 12px; font-weight: 600; text-decoration: none; }
    .forgot-link:hover { text-decoration: underline; }
  </style>
</head>

<body>
  <!-- Top Bar -->
  <div class="top-bar">
    <div class="top-bar-content">
      <div class="top-bar-left">
        <a href="#" class="top-link" onclick="showToast('Support Coming Soon!')">SUPPORT</a>
        <span class="top-divider">|</span>
        <a href="#" class="top-link" id="signInTopBtn" onclick="openAuthModal()">SIGN IN</a>
      </div>
      <div class="top-bar-right">
        <a href="#" class="top-link" onclick="openSettingsModal()"><i class="fas fa-globe"></i> Global / English</a>
      </div>
    </div>
  </div>

  <!-- Main Header -->
  <header>
    <div class="header-container">
      <div class="logo">
        <a href="#" onclick="if(window.showAllProducts){showAllProducts(); window.scrollTo({top:0,behavior:'smooth'});} return false;">
          <i class="fas fa-tools"></i>
          <span>BUILDMATRIX</span>
        </a>
      </div>

      <nav class="main-nav">
        <div class="nav-item has-dropdown">
          <a href="#" class="nav-link">GUIDES <i class="fas fa-chevron-down"></i></a>
          <div class="dropdown">
            <div class="dropdown-content">
              <a href="#" onclick="openArticle('diy'); return false;">🔧 DIY Builder Guides</a>
              <a href="#" onclick="openArticle('cooling'); return false;">❄️ Cooling Guides</a>
              <a href="#" onclick="openArticle('overclocking'); return false;">⚡ Overclocking Guides</a>
              <a href="#" onclick="openArticle('troubleshooting'); return false;">🔍 Troubleshooting</a>
              <a href="#" onclick="openArticle('fans'); return false;">🌀 Fans - Everything You Need</a>
            </div>
          </div>
        </div>

        <div class="nav-item has-dropdown">
          <a href="#" class="nav-link">SOFTWARE <i class="fas fa-chevron-down"></i></a>
          <div class="dropdown">
            <div class="dropdown-content">
              <a href="#" onclick="openArticle('studio'); return false;">🎨 BuildMatrix Studio</a>
              <a href="#" onclick="openArticle('compatibility'); return false;">✓ Compatibility Checker</a>
              <a href="#" onclick="openArticle('performance'); return false;">📊 Performance Analyzer</a>
              <a href="#" onclick="openArticle('budget'); return false;">💰 Budget Calculator</a>
            </div>
          </div>
        </div>

        <div class="nav-item">
          <a href="#" class="nav-link" onclick="toggleSearch()"><i class="fas fa-search"></i></a>
        </div>
      </nav>

      <div class="user-menu-container" id="userMenuContainer" style="display:none; position:relative;">
        <div class="user-menu-trigger" onclick="toggleUserMenu()" id="userMenuTrigger">
          <div class="um-avatar" id="umAvatar">P</div>
          <span id="userNameHeader">User</span>
          <i class="fas fa-chevron-down" id="umChevron"></i>
        </div>
        <div class="user-dropdown" id="userDropdown">
          <div class="ud-header">
            <div class="ud-avatar" id="udAvatar">P</div>
            <div class="ud-info">
              <strong id="udName">User</strong>
              <span id="udEmail">user@email.com</span>
            </div>
          </div>
          <a href="my-builds.html"><i class="fas fa-folder"></i> My Builds</a>
          <a href="#" onclick="openSecuritySettings(); return false;"><i class="fas fa-shield-alt"></i> Security Settings</a>
          <a href="admin.html" id="adminMenuBtn" style="display:none;"><i class="fas fa-crown"></i> Admin Panel</a>
          <hr>
          <a href="#" onclick="doSignOut(); return false;" class="ud-signout"><i class="fas fa-sign-out-alt"></i> Sign Out</a>
        </div>
      </div>

      <button class="sign-in-btn" id="signInBtn" onclick="openAuthModal()">SIGN IN</button>
      <button class="header-dark-toggle" id="headerDarkToggle" onclick="toggleDarkLight()" title="Toggle dark/light mode"><i class="fas fa-moon" id="darkToggleIcon"></i></button>
    </div>
  </header>

  <!-- VIDEO HERO SECTION -->
  <div class="video-hero">
    <div class="video-overlay"></div>
    <video autoplay muted loop playsinline class="hero-video" id="heroBackgroundVideo">
      <source src="Images/rtx-5090.mp4" type="video/mp4">
      Your browser does not support the video tag.
    </video>
    <button class="hero-mute-btn" id="heroMuteBtn" onclick="toggleHeroMute()" title="Toggle sound">
      <i class="fas fa-volume-mute" id="heroMuteIcon"></i>
    </button>
    <div class="hero-content">
      <div class="hero-badge">RTX 50 SERIES</div>
      <h1 class="hero-title">NVIDIA GeForce RTX 5090</h1>
      <p class="hero-subtitle">The Next Generation of Gaming • DLSS 4 • Neural Rendering</p>
      <div class="hero-buttons">
        <button class="hero-btn primary" onclick="filterCategory('gpu')">BROWSE GPUs</button>
        <button class="hero-btn secondary" onclick="document.getElementById('builder-container').scrollIntoView({behavior:'smooth',block:'start'})">START BUILDING</button>
      </div>
      <div class="hero-stats">
        <div class="stat">
          <span class="stat-value">2x</span>
          <span class="stat-label">Performance vs RTX 4090</span>
        </div>
        <div class="stat">
          <span class="stat-value">32GB</span>
          <span class="stat-label">GDDR7 Memory</span>
        </div>
        <div class="stat">
          <span class="stat-value">DLSS 4</span>
          <span class="stat-label">AI-Powered</span>
        </div>
      </div>
    </div>
  </div>

  <!-- GUIDES SECTION -->
  <div class="guides-section">
    <div class="section-header reveal">
      <h2>BUILD GUIDES & TUTORIALS</h2>
      <a href="#" class="section-link" onclick="showToast('More Guides Coming Soon!')">VIEW ALL GUIDES <i class="fas fa-arrow-right"></i></a>
    </div>
    
    <div class="guides-grid">
      <div class="guide-card" onclick="openArticle('cpu')" style="cursor:pointer;">
        <div class="guide-image"><i class="fas fa-microchip"></i></div>
        <div class="guide-content">
          <span class="guide-badge">GUIDE</span>
          <h3>How to Choose the Right CPU for Your Build</h3>
          <button class="read-more">READ GUIDE</button>
        </div>
      </div>
      
      <div class="guide-card" onclick="openArticle('build')" style="cursor:pointer;">
        <div class="guide-image"><i class="fas fa-keyboard"></i></div>
        <div class="guide-content">
          <span class="guide-badge">GUIDE</span>
          <h3>PC Building: Step by Step for Beginners</h3>
          <button class="read-more">READ GUIDE</button>
        </div>
      </div>
      
      <div class="guide-card" onclick="openArticle('airflow')" style="cursor:pointer;">
        <div class="guide-image"><i class="fas fa-fan"></i></div>
        <div class="guide-content">
          <span class="guide-badge">GUIDE</span>
          <h3>Case Airflow Optimization Guide</h3>
          <button class="read-more">READ GUIDE</button>
        </div>
      </div>
    </div>
  </div>

  <!-- Main PC Builder Layout -->
  <div class="builder-container" id="builder-container">
    <aside class="builder-sidebar">
      <div class="sidebar-header">
        <h3>COMPONENTS</h3>
        <i class="fas fa-arrow-right"></i>
      </div>
      
      <div class="categories-list">
        <button class="category-item" data-category="cpu">
          <span><i class="fas fa-microchip"></i> Processors (CPU)</span><span class="cat-count" id="cnt-cpu">0</span>
        </button>
        <button class="category-item" data-category="gpu">
          <span><i class="fas fa-tv"></i> Graphics Cards (GPU)</span><span class="cat-count" id="cnt-gpu">0</span>
        </button>
        <button class="category-item" data-category="motherboard">
          <span><i class="fas fa-server"></i> Motherboards</span><span class="cat-count" id="cnt-motherboard">0</span>
        </button>
        <button class="category-item" data-category="ram">
          <span><i class="fas fa-memory"></i> Memory (RAM)</span><span class="cat-count" id="cnt-ram">0</span>
        </button>
        <button class="category-item" data-category="ssd">
          <span><i class="fas fa-database"></i> Storage (SSD/HDD)</span><span class="cat-count" id="cnt-ssd">0</span>
        </button>
        <button class="category-item" data-category="psu">
          <span><i class="fas fa-bolt"></i> Power Supplies</span><span class="cat-count" id="cnt-psu">0</span>
        </button>
        <button class="category-item" data-category="case">
          <span><i class="fas fa-desktop"></i> PC Cases</span><span class="cat-count" id="cnt-case">0</span>
        </button>
        <button class="category-item" data-category="monitor">
          <span><i class="fas fa-display"></i> Monitors</span><span class="cat-count" id="cnt-monitor">0</span>
        </button>
        <button class="category-item" data-category="fan">
          <span><i class="fas fa-fan"></i> Cooling Fans</span><span class="cat-count" id="cnt-fan">0</span>
        </button>
        <button class="category-item" data-category="keyboard">
          <span><i class="fas fa-keyboard"></i> Keyboards</span><span class="cat-count" id="cnt-keyboard">0</span>
        </button>
        <button class="category-item" data-category="mouse">
          <span><i class="fas fa-mouse"></i> Mice</span><span class="cat-count" id="cnt-mouse">0</span>
        </button>
      </div>
    </aside>

    <main class="builder-main">
      <div class="product-controls">
        <div class="product-search-wrap">
          <i class="fas fa-search"></i>
          <input type="text" class="product-search" id="productSearch" placeholder="Search components..." oninput="applyAllFilters()">
        </div>
        <select class="sort-select" id="sortSelect" onchange="applyAllFilters()">
          <option value="default">Sort: Default</option>
          <option value="price-asc">Price: Low → High</option>
          <option value="price-desc">Price: High → Low</option>
          <option value="name-asc">Name: A → Z</option>
        </select>
        <div class="price-range-wrap">
          <i class="fas fa-tag" style="font-size:11px;"></i>
          <input type="range" id="priceRange" min="0" max="200000" step="1000" value="200000" oninput="applyAllFilters()">
          <span class="price-range-label" id="priceRangeLabel">All</span>
        </div>
      </div>

      <div class="sub-filter-bar" id="subFilterBar">
        <button class="sub-filter-btn active" data-filter="all" onclick="applySubFilter('all', this)">All</button>
        <button class="sub-filter-btn" data-filter="amd-cpu" onclick="applySubFilter('amd-cpu', this)"><i class="fab fa-amd"></i> AMD CPUs</button>
        <button class="sub-filter-btn" data-filter="intel-cpu" onclick="applySubFilter('intel-cpu', this)"><i class="fas fa-microchip"></i> Intel CPUs</button>
        <button class="sub-filter-btn" data-filter="amd-gpu" onclick="applySubFilter('amd-gpu', this)"><i class="fab fa-amd"></i> AMD GPUs</button>
        <button class="sub-filter-btn" data-filter="nvidia-gpu" onclick="applySubFilter('nvidia-gpu', this)"><i class="fas fa-tv"></i> NVIDIA GPUs</button>
      </div>

      <div id="productsContainer" class="products-grid">
        <div class="loading-spinner">
          <div class="spinner"></div>
          <p style="margin-top: 20px;">Loading components...</p>
        </div>
      </div>
    </main>

    <aside class="build-panel">
      <div class="build-header">
        <h2>YOUR BUILD</h2>
        <button class="clear-all" id="clearAllBtn" onclick="clearAllBuild()" style="display: none;">Clear All</button>
      </div>
      
      <div id="selectedParts" class="selected-parts">
        <div class="empty-build">
          <i class="fas fa-tools"></i>
          <h3>No components selected</h3>
          <p>Click "Add to Build" on any component</p>
        </div>
      </div>

      <div class="total-cost">
        <span>Total:</span>
        <span id="totalPrice">₱0</span>
      </div>

      <div class="build-actions">
        <button class="action-btn save" onclick="saveCurrentBuild()">
          <i class="fas fa-save"></i> Save Build
        </button>
        <button class="action-btn screenshot" onclick="downloadScreenshot()">
          <i class="fas fa-camera"></i> Screenshot
        </button>
        <button class="action-btn pdf" onclick="downloadPDF()">
          <i class="fas fa-file-pdf"></i> Export PDF
        </button>
      </div>

      <div class="java-actions" style="display: flex; gap: 10px; margin: 15px 0;">
        <button class="action-btn" style="flex:1; background: var(--gold); color: var(--bg-dark);" onclick="runJavaScore()">
          <i class="fas fa-chart-line"></i> Analyze Build
        </button>
        <button class="action-btn" style="flex:1;" onclick="runJavaBudget()">
          <i class="fas fa-coins"></i> Budget Guide
        </button>
      </div>

      <div id="compatibilityPanel" class="compatibility-panel" style="display: none;">
        <h3><i class="fas fa-chart-line"></i> Compatibility Analysis</h3>
        <div id="compatibilityList"></div>
      </div>

      <div id="perfScorePanel" class="perf-score-panel" style="display:none;">
        <h3><i class="fas fa-tachometer-alt" style="color:var(--gold);"></i> Performance Score</h3>
        <div class="perf-row">
          <div class="perf-row-header"><span class="perf-row-label">🎮 Gaming</span><span class="perf-row-val" id="perfGaming">0</span></div>
          <div class="perf-bar-track"><div class="perf-bar-fill" id="perfGamingBar" style="width:0%"></div></div>
        </div>
        <div class="perf-row">
          <div class="perf-row-header"><span class="perf-row-label">💼 Productivity</span><span class="perf-row-val" id="perfProd">0</span></div>
          <div class="perf-bar-track"><div class="perf-bar-fill" id="perfProdBar" style="width:0%;background:linear-gradient(90deg,#00aaff,#0066cc)"></div></div>
        </div>
        <div class="perf-row">
          <div class="perf-row-header"><span class="perf-row-label">📡 Streaming</span><span class="perf-row-val" id="perfStream">0</span></div>
          <div class="perf-bar-track"><div class="perf-bar-fill" id="perfStreamBar" style="width:0%;background:linear-gradient(90deg,#aa44ff,#7722cc)"></div></div>
        </div>
      </div>

      <div class="promo-card" onclick="openVideoModal()">
        <div class="promo-icon">
          <i class="fas fa-play-circle"></i>
        </div>
        <div class="promo-content">
          <h4>Watch: RTX 5090 Overview</h4>
          <p>See the next generation of gaming performance</p>
        </div>
      </div>

      <div class="features-grid">
        <div class="feature-item">
          <i class="fas fa-chart-line"></i>
          <h4>Real-time Compatibility</h4>
          <p>Automatic part matching</p>
        </div>
        <div class="feature-item">
          <i class="fas fa-calculator"></i>
          <h4>Budget Calculator</h4>
          <p>Smart allocation guide</p>
        </div>
        <div class="feature-item">
          <i class="fas fa-chart-simple"></i>
          <h4>Performance Score</h4>
          <p>Estimate your build's power</p>
        </div>
      </div>

      <button class="share-btn" onclick="shareBuild()">
        <i class="fas fa-share-alt"></i> Share Build
      </button>
    </aside>
  </div>

  <!-- Newsletter Section -->
  <div class="newsletter-section">
    <div class="newsletter-content">
      <h2>Get build tips, new component alerts, and PC building guides straight to your inbox.</h2>
      <div class="newsletter-form">
        <input type="email" placeholder="Email Address" id="newsletterEmail">
        <button onclick="subscribeNewsletter()">SUBSCRIBE</button>
